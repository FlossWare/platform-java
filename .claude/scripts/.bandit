[bandit]
# Bandit configuration for review automation scripts
# These scripts need to call external commands (gh CLI) which triggers
# security warnings, but the commands are trusted and inputs are controlled.

# Suppress subprocess warnings - we need to call gh CLI
skips = B404,B602,B603,B607

# Suppress MD5 warning - not used for security (was removed anyway)
exclude = */create_github_issues.py
